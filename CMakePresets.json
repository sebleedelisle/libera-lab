{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 15, "patch": 0 },
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "LIBERA_USE_BUNDLED_LIBUSB": "ON",
        "LIBERA_BUILD_TESTS": "OFF",
        "LIBERA_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0",
        "LIBERA_USE_BUNDLED_LIBUSB": "ON",
        "LIBERA_BUILD_TESTS": "OFF",
        "LIBERA_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Release (Ninja, Linux)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LIBERA_BUILD_TESTS": "OFF",
        "LIBERA_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "win-release",
      "displayName": "Release (Visual Studio)",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LIBERA_BUILD_TESTS": "OFF",
        "LIBERA_BUILD_EXAMPLES": "OFF",
        "LIBERA_USE_BUNDLED_LIBUSB": "ON"
      }
    },
    {
      "name": "win-debug",
      "displayName": "Debug (Visual Studio)",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LIBERA_BUILD_TESTS": "OFF",
        "LIBERA_BUILD_EXAMPLES": "OFF",
        "LIBERA_USE_BUNDLED_LIBUSB": "ON"
      }
    }
  ]
}
